+static std::unordered_set<u32> trace_instrs;
+
+void device_debug::dump()
+{
+	emu_file file("/tmp/fuzz", OPEN_FLAG_CREATE | OPEN_FLAG_WRITE);
+	std::error_condition const err = file.open("dump");
+	if (err)
+	{
+		osd_printf_error("%s\n", err.message());
+		return;
+	}
+
+	std::set<u32> trace_instrs_sorted(trace_instrs.begin(), trace_instrs.end());
+	u32 buf;
+	for (auto it = trace_instrs.begin(); it != trace_instrs.end(); it++)
+	{
+		buf = *it;
+		file.write(&buf, sizeof(buf));
+	}
+	file.close();
+}
 
