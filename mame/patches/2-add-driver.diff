index 00000000000..66b6d1bda84
--- /dev/null
+++ b/src/mame/fuzz/x86_16.cpp
@@ -0,0 +1,62 @@
+// license:BSD-3-Clause
+// copyright-holders:
+
+#include "emu.h"
+
+#include "cpu/i86/i286.h"
+
+namespace {
+
+class x86_16_state : public driver_device
+{
+public:
+	x86_16_state(const machine_config &mconfig, device_type type, const char *tag)
+		: driver_device(mconfig, type, tag)
+		, m_maincpu(*this, "maincpu")
+	{ }
+
+	void fuzz_x86_16(machine_config &config);
+
+protected:
+	virtual void machine_start() override ATTR_COLD;
+
+private:
+	required_device<cpu_device> m_maincpu;
+
+	void x86_16_io_map(address_map &map) ATTR_COLD;
+	void x86_16_map(address_map &map) ATTR_COLD;
+};
+
+void x86_16_state::machine_start()
+{
+}
+
+void x86_16_state::x86_16_io_map(address_map &map)
+{
+	map.global_mask(0xffff);
+}
+
+void x86_16_state::x86_16_map(address_map &map)
+{
+	map(0x000000, 0x00dfff).mirror(0xff0000).rom().region("rom", 0);
+	map(0x00e000, 0x00efff).mirror(0xff0000).ram();
+	map(0x00f000, 0x00ffff).mirror(0xff0000).rom().region("rom", 0xf000);
+}
+
+void x86_16_state::fuzz_x86_16(machine_config &config)
+{
+	I80286(config, m_maincpu, 16_MHz_XTAL);
+	m_maincpu->set_addrmap(AS_PROGRAM, &x86_16_state::x86_16_map);
+	m_maincpu->set_addrmap(AS_IO, &x86_16_state::x86_16_io_map);
+}
+
+
+ROM_START( fuzz_x86_16 )
+	ROM_REGION(0x10000, "rom", 0)
+	ROM_LOAD("rom", 0x000000, 0x010000, CRC(12345678) SHA1(1234567812345678123456781234567812345678))
+ROM_END
+
+} // anonymous namespace
+
+
+COMP( 2XXX,  fuzz_x86_16,    0,      0,      fuzz_x86_16, 0,     x86_16_state, empty_init, "fuzz_x86_16", "fuzz_x86_16", MACHINE_NOT_WORKING|MACHINE_NO_SOUND )
